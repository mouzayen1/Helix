# Helix — auth + Supabase environment variables.
#
# Copy this file to `.env.local` and fill in the values for your environment.
# `.env.local` is gitignored; never commit real keys.
#
# Naming rule:
#   - `EXPO_PUBLIC_*` is shipped to the client at build time. Use only for
#     publishable / non-secret values (Supabase anon key, Google client IDs).
#   - Unprefixed vars are server-only (Supabase service role key, Apple .p8
#     private key contents). Keep these in the Supabase dashboard / EAS
#     secrets — never reference them from app code.

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL — e.g. https://abcdefghij.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Anon (publishable) key — safe to ship to clients. Found in:
# Supabase Dashboard → Project Settings → API → Project API keys → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SECRET. Used only for local migrations / admin scripts.
# Found in the same panel as the anon key, labeled "service_role".
# DO NOT prefix this with EXPO_PUBLIC_; if you do, it ships to every client.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string for psql migrations.
# Format: postgresql://postgres.<project-ref>:<password>@<host>:<port>/postgres
# Found in: Project Settings → Database → Connection string → URI
DATABASE_URL=

# ─── Admin signup notifications ─────────────────────────────────────────────
#
# Server-only secrets for the Supabase Edge Function at:
#   supabase/functions/admin-signup-email
# Set these with `supabase secrets set ...`; do not prefix them with
# EXPO_PUBLIC_.

# Resend API key used to email admins when a profile row is created.
RESEND_API_KEY=

# Comma-separated admin recipients for new-user notifications.
ADMIN_SIGNUP_EMAILS=mouzayen1@gmail.com,smitty6123@gmail.com

# From address. The domain must be verified in Resend before production use.
ADMIN_SIGNUP_FROM=Helix <notifications@gethelixapp.org>

# Shared secret expected in the database webhook's x-helix-webhook-secret header.
ADMIN_SIGNUP_WEBHOOK_SECRET=

# ─── Google Sign-In ──────────────────────────────────────────────────────────

# iOS OAuth 2.0 client ID — used by the native iOS Google Sign-In SDK.
# Created in Google Cloud Console → APIs & Services → Credentials → iOS.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Android OAuth 2.0 client ID — used by the native Android Google Sign-In SDK.
# Created in the same place; pick "Android" and provide the SHA-1 fingerprint
# of your app's signing keystore.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Web OAuth 2.0 client ID — used by Supabase as the OAuth backend. The
# CLIENT_SECRET is configured in Supabase's Auth provider settings, not here.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ─── Sign in with Apple ──────────────────────────────────────────────────────
#
# NATIVE iOS: no client-side env vars needed. Apple sign-in is configured via:
#  - app.json: `ios.usesAppleSignIn: true` + plugin "expo-apple-authentication"
#  - Apple Developer Console: App ID with "Sign in with Apple" capability
#  - Supabase Dashboard → Auth → Providers → Apple, paste:
#      - Service ID
#      - Team ID
#      - Key ID
#      - .p8 private key contents
#
# The Supabase JS client receives Apple's identity token from the native
# component and exchanges it for a Supabase session — no Apple credentials
# ever live in client code.
#
# WEB ("Sign in with Apple" on app.gethelixapp.org): requires an Apple
# Services ID + Key + web-domain association (Apple Developer) AND the
# Apple provider enabled for web in Supabase. Once that's in place, set
# the flag below to "true" in the web build env (Vercel) and redeploy to
# surface the Apple button on the web sign-up screen. Leave blank/false
# until the config exists, or users get an OAuth error on click.
EXPO_PUBLIC_ENABLE_APPLE_WEB_SIGN_IN=

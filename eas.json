{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview-ios": {
      "distribution": "store",
      "channel": "preview",
      "environment": "preview",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "channel": "production"
    }
  },
  "submit": {
    "preview-ios": {
      "ios": {
        "appleId": "drpepperandhookah@gmail.com",
        "ascAppId": "6769559763",
        "appleTeamId": "PUHZTA99Y2"
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}

{
  "expo": {
    "name": "Helix",
    "slug": "helix",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "helix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.helix.demo"
    },
    "android": {
      "package": "app.helix.demo",
      "adaptiveIcon": {
        "backgroundColor": "#0A8E83",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A8E83",
          "dark": {
            "backgroundColor": "#0E1113"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
